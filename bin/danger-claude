#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "optparse"

IMAGE_NAME = "danger-claude"
VOLUME_NAME = "danger-claude"
MISE_VOLUME_NAME = "danger-claude-mise"
GH_VOLUME_NAME = "danger-claude-gh"

def run(*cmd)
  system(*cmd) || exit($?.exitstatus)
end

def docker_volume_exists?(name)
  output, status = Open3.capture2("docker", "volume", "inspect", name)
  status.success?
end

def ensure_volume(name)
  return if docker_volume_exists?(name)

  run("docker", "volume", "create", name)
end

def build
  prefix = File.expand_path("../..", File.realpath(__FILE__))
  dockerfile = File.join(prefix, "Dockerfile")
  unless File.exist?(dockerfile)
    abort "Error: Dockerfile not found at #{dockerfile}"
  end
  run("docker", "build", "-t", IMAGE_NAME, "-f", dockerfile, prefix)
end

def git_config(key)
  output, status = Open3.capture2("git", "config", "--get", key)
  status.success? ? output.strip : nil
end

def git_env_args
  args = []
  name = git_config("user.name")
  email = git_config("user.email")
  args.push("-e", "GIT_AUTHOR_NAME=#{name}", "-e", "GIT_COMMITTER_NAME=#{name}") if name
  args.push("-e", "GIT_AUTHOR_EMAIL=#{email}", "-e", "GIT_COMMITTER_EMAIL=#{email}") if email
  args
end

def ssh_agent_args
  sock = ENV["SSH_AUTH_SOCK"]
  return [] unless sock && File.exist?(sock)

  if RUBY_PLATFORM =~ /darwin/
    # On macOS, Docker Desktop exposes the SSH agent via a VM-internal socket
    # with correct permissions, avoiding the root-owned socket issue from
    # direct host socket mounts.
    ["-v", "/run/host-services/ssh-auth.sock:/ssh-agent", "-e", "SSH_AUTH_SOCK=/ssh-agent"]
  else
    ["-v", "#{sock}:/ssh-agent", "-e", "SSH_AUTH_SOCK=/ssh-agent"]
  end
end

def gh_token_args
  token = ENV["GH_TOKEN"] || ENV["GITHUB_TOKEN"]
  return [] unless token

  ["-e", "GH_TOKEN=#{token}"]
end

def start(command_args, git_readonly: true, extra_volumes: [])
  ensure_volume(VOLUME_NAME)
  ensure_volume(MISE_VOLUME_NAME)
  ensure_volume(GH_VOLUME_NAME)

  workdir = File.basename(Dir.pwd)
  git_mount = "#{Dir.pwd}/.git:/home/claude/#{workdir}/.git"
  git_mount += ":ro" if git_readonly

  volume_args = extra_volumes.flat_map do |vol|
    mount = vol.include?(":") ? vol : "#{vol}:#{vol}"
    ["-v", mount]
  end

  docker_cmd = [
    "docker", "run", "--rm",
    "-v", "#{Dir.pwd}:/home/claude/#{workdir}",
    "-v", git_mount,
    "-v", "#{VOLUME_NAME}:/home/claude/.claude",
    "-v", "#{MISE_VOLUME_NAME}:/home/claude/.local/share/mise",
    "-v", "#{GH_VOLUME_NAME}:/home/claude/.config/gh",
    *volume_args,
    *git_env_args,
    *ssh_agent_args,
    *gh_token_args,
    "-w", "/home/claude/#{workdir}",
    "-ti",
    IMAGE_NAME,
    *command_args
  ]

  run(*docker_cmd)
end

options = { volumes: [] }
OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage: danger-claude [options] [-- command...]

    Examples:
      danger-claude                         # Run claude (default)
      danger-claude -s                      # Open a shell
      danger-claude -p "explain this code"  # Print mode (non-interactive)
      danger-claude -c                      # Auto-commit all changes
      danger-claude -- claude -p "hello"    # Run claude with custom args
  BANNER

  opts.on("-b", "--build", "Build the Docker image") do
    options[:build] = true
  end

  opts.on("-s", "--shell", "Open a bash shell") do
    options[:shell] = true
  end

  opts.on("-p", "--print PROMPT", "Run claude in print mode with the given prompt (skipping permissions)") do |prompt|
    options[:print] = prompt
  end

  opts.on("-c", "--commit", "Auto-commit all changes with a detailed commit message") do
    options[:commit] = true
  end

  opts.on("-v", "--volume PATH", "Mount an additional volume (host_path or host_path:container_path)") do |vol|
    options[:volumes] << vol
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end.parse!

if options[:build]
  build
elsif options[:shell]
  start(["bash"], extra_volumes: options[:volumes])
elsif options[:print]
  start(["claude", "-p", "--dangerously-skip-permissions", options[:print]], extra_volumes: options[:volumes])
elsif options[:commit]
  commit_prompt = <<~PROMPT
    Review all current git changes (staged and unstaged), add all changes, and create a single commit with a precise and detailed commit message. \
    The commit message should have a concise summary line followed by a detailed body explaining what changed and why. \
    Do not push. Do not ask for confirmation.
  PROMPT
  start(["claude", "-p", "--dangerously-skip-permissions", commit_prompt.strip], git_readonly: false, extra_volumes: options[:volumes])
else
  start(ARGV, extra_volumes: options[:volumes])
end
