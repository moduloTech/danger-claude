#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "optparse"

VERSION = "0.2.0"
IMAGE_NAME = "danger-claude"
VOLUME_NAME = "danger-claude"
MISE_VOLUME_NAME = "danger-claude-mise"
GH_VOLUME_NAME = "danger-claude-gh"

def run(*cmd)
  system(*cmd) || exit($?.exitstatus)
end

def docker_volume_exists?(name)
  output, status = Open3.capture2("docker", "volume", "inspect", name)
  status.success?
end

def ensure_volume(name)
  return if docker_volume_exists?(name)

  run("docker", "volume", "create", name)
end

def build
  prefix = File.expand_path("../..", File.realpath(__FILE__))
  dockerfile = File.join(prefix, "Dockerfile")
  unless File.exist?(dockerfile)
    abort "Error: Dockerfile not found at #{dockerfile}"
  end
  run("docker", "build", "-t", IMAGE_NAME, "-f", dockerfile, prefix)
end

def git_config(key)
  output, status = Open3.capture2("git", "config", "--get", key)
  status.success? ? output.strip : nil
end

def git_env_args
  args = []
  name = git_config("user.name")
  email = git_config("user.email")
  args.push("-e", "GIT_AUTHOR_NAME=#{name}", "-e", "GIT_COMMITTER_NAME=#{name}") if name
  args.push("-e", "GIT_AUTHOR_EMAIL=#{email}", "-e", "GIT_COMMITTER_EMAIL=#{email}") if email
  args
end

def ssh_agent_args
  sock = ENV["SSH_AUTH_SOCK"]
  return [] unless sock && File.exist?(sock)

  if RUBY_PLATFORM =~ /darwin/
    # On macOS, Docker Desktop exposes the SSH agent via a VM-internal socket
    # with correct permissions, avoiding the root-owned socket issue from
    # direct host socket mounts.
    ["-v", "/run/host-services/ssh-auth.sock:/ssh-agent", "-e", "SSH_AUTH_SOCK=/ssh-agent"]
  else
    ["-v", "#{sock}:/ssh-agent", "-e", "SSH_AUTH_SOCK=/ssh-agent"]
  end
end

def gh_token_args
  token = ENV["GH_TOKEN"] || ENV["GITHUB_TOKEN"]
  return [] unless token

  ["-e", "GH_TOKEN=#{token}"]
end

def mise_trusted_paths_args(workdir, extra_volumes)
  paths = ["/home/claude/#{workdir}"]
  extra_volumes.each do |vol|
    container_path = vol.include?(":") ? vol.split(":", 2).last : vol
    paths << container_path
  end
  ["-e", "MISE_TRUSTED_PATHS=#{paths.join(":")}"]
end

def start(command_args, git_readonly: true, extra_volumes: [])
  ensure_volume(VOLUME_NAME)
  ensure_volume(MISE_VOLUME_NAME)
  ensure_volume(GH_VOLUME_NAME)

  workdir = File.basename(Dir.pwd)
  git_mount = "#{Dir.pwd}/.git:/home/claude/#{workdir}/.git"
  git_mount += ":ro" if git_readonly

  volume_args = extra_volumes.flat_map do |vol|
    mount = vol.include?(":") ? vol : "#{vol}:#{vol}"
    ["-v", mount]
  end

  docker_cmd = [
    "docker", "run", "--rm",
    "-v", "#{Dir.pwd}:/home/claude/#{workdir}",
    "-v", git_mount,
    "-v", "#{VOLUME_NAME}:/home/claude/.claude",
    "-v", "#{MISE_VOLUME_NAME}:/home/claude/.local/share/mise",
    "-v", "#{GH_VOLUME_NAME}:/home/claude/.config/gh",
    *volume_args,
    *git_env_args,
    *ssh_agent_args,
    *gh_token_args,
    *mise_trusted_paths_args(workdir, extra_volumes),
    "-w", "/home/claude/#{workdir}",
    *($stdin.tty? ? ["-ti"] : ["-i"]),
    IMAGE_NAME,
    *command_args
  ]

  run(*docker_cmd)
end

options = { volumes: [] }
OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage: danger-claude [options] [-- command...]

    Run Claude CLI inside a containerized environment.

    Modes (mutually exclusive):
      danger-claude                         Interactive claude session (.git read-only)
      danger-claude -s                      Open a bash shell
      danger-claude -p "explain this code"  Print mode (non-interactive, .git read-only)
      danger-claude -p "fix" -a mr-fixer    Print mode with a specific subagent
      danger-claude -c                      Auto-commit all changes (.git read-write)
      danger-claude -- claude -p "hello"    Run custom command

    Options:
  BANNER

  opts.on("-b", "--build", "Build the Docker image") do
    options[:build] = true
  end

  opts.on("-s", "--shell", "Open a bash shell") do
    options[:shell] = true
  end

  opts.on("-p", "--print PROMPT", "Run claude in print mode with the given prompt") do |prompt|
    options[:print] = prompt
  end

  opts.on("-a", "--agent NAME", "Use a specific subagent (passed as --agent to claude)") do |name|
    options[:agent] = name
  end

  opts.on("--max-turns N", Integer, "Maximum agent turns (passed to claude)") do |n|
    options[:max_turns] = n
  end

  opts.on("--output-format FORMAT", "Output format: text, json, stream-json (passed to claude)") do |fmt|
    options[:output_format] = fmt
  end

  opts.on("--json-schema SCHEMA", "JSON schema for structured output (passed to claude)") do |schema|
    options[:json_schema] = schema
  end

  opts.on("-m", "--model MODEL", "Model to use (passed as --model to claude)") do |model|
    options[:model] = model
  end

  opts.on("-e", "--effort LEVEL", "Effort level: low, medium, high (passed as --effort to claude)") do |level|
    options[:effort] = level
  end

  opts.on("-c", "--commit", "Auto-commit all changes (implies --git-rw)") do
    options[:commit] = true
  end

  opts.on("-g", "--git-rw", "Mount .git as read-write (default: read-only)") do
    options[:git_rw] = true
  end

  opts.on("-v", "--volume PATH", "Mount an additional volume (host_path or host_path:container_path)") do |vol|
    options[:volumes] << vol
  end

  opts.on("--version", "Show version and exit") do
    puts "danger-claude #{VERSION}"
    exit
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end.parse!

git_rw = options[:git_rw] || options[:commit]

if options[:build]
  build
elsif options[:shell]
  start(["bash"], git_readonly: !git_rw, extra_volumes: options[:volumes])
elsif options[:print]
  claude_cmd = ["claude", "-p", "--dangerously-skip-permissions"]
  claude_cmd.push("--agent", options[:agent]) if options[:agent]
  claude_cmd.push("--max-turns", options[:max_turns].to_s) if options[:max_turns]
  claude_cmd.push("--output-format", options[:output_format]) if options[:output_format]
  claude_cmd.push("--json-schema", options[:json_schema]) if options[:json_schema]
  claude_cmd.push("--model", options[:model]) if options[:model]
  claude_cmd.push("--effort", options[:effort]) if options[:effort]
  claude_cmd.push(options[:print])
  start(claude_cmd, git_readonly: !git_rw, extra_volumes: options[:volumes])
elsif options[:commit]
  commit_prompt = <<~PROMPT
    Review all current git changes (staged and unstaged), add all changes, and create a single commit. \
    Use Conventional Commits format: `<type>: <description>` summary line followed by a blank line and a detailed body explaining what changed and why. \
    Types: feat (new feature), fix (bug fix), refactor (no behavior change), test, docs, chore (maintenance). \
    Do not push. Do not ask for confirmation.
  PROMPT
  commit_cmd = ["claude", "-p", "--dangerously-skip-permissions"]
  commit_cmd.push("--model", options[:model]) if options[:model]
  commit_cmd.push("--effort", options[:effort]) if options[:effort]
  commit_cmd.push(commit_prompt.strip)
  start(commit_cmd, git_readonly: false, extra_volumes: options[:volumes])
else
  start(ARGV, git_readonly: !git_rw, extra_volumes: options[:volumes])
end
